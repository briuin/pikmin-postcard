# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/pikmin_postcard?schema=public

# Gemini
GOOGLE_GENERATIVE_AI_API_KEY=replace_with_gemini_key
GEMINI_MODEL=gemini-2.0-flash

# Optional app storage/auth settings
S3_BUCKET_NAME=your-postcard-bucket
S3_REGION=us-east-1
# Optional: public base URL if you serve via CloudFront
S3_PUBLIC_BASE_URL=
