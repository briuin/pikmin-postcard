# Auth (Google only)
GOOGLE_CLIENT_ID=replace_with_google_oauth_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_oauth_client_secret
NEXT_PUBLIC_GOOGLE_CLIENT_ID=replace_with_google_oauth_client_id
APP_JWT_SECRET=replace_with_random_long_secret
NEW_USER_APPROVAL_MODE=auto
OPENNEXT_ENABLE_DOMAIN=false
OPENNEXT_DOMAIN_NAME=pikmin.askans.app
OPENNEXT_ROUTE53_ZONE_ID=Z07732472U0GRGAK1E05W
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Gemini
GOOGLE_GENERATIVE_AI_API_KEY=replace_with_gemini_key
GEMINI_MODEL=gemini-2.5-flash

# Optional app storage/auth settings
S3_BUCKET_NAME=your-postcard-bucket
S3_REGION=us-east-1
DDB_TABLE_PREFIX=pikmin-postcard-dev
POSTCARD_GEO_BUCKET_DEGREES=2
POSTCARD_GEO_BUCKET_LEVELS=2,8,60
POSTCARD_EXPLORE_REQUIRE_LEGACY_FALLBACK=true
POSTCARD_PUBLIC_CACHE_TTL_SECONDS=15
POSTCARD_PUBLIC_CACHE_MAX_ENTRIES=200
DETECTION_QUEUE_URL=
# Optional: public base URL if you serve via CloudFront
S3_PUBLIC_BASE_URL=
APK_DOWNLOAD_METADATA_URL=
APK_DOWNLOAD_FALLBACK_URL=

# Optional reverse geocoding settings (defaults to OpenStreetMap Nominatim)
REVERSE_GEOCODE_ENDPOINT=https://nominatim.openstreetmap.org/reverse
REVERSE_GEOCODE_LANG=en
REVERSE_GEOCODE_USER_AGENT=pikmin-postcard/1.0 (+https://pikmin.askans.app)
