{
  "family": "pikmin-postcard-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::123456789012:role/pikmin-postcard-task-execution",
  "taskRoleArn": "arn:aws:iam::123456789012:role/pikmin-postcard-task",
  "containerDefinitions": [
    {
      "name": "pikmin-postcard-app",
      "image": "123456789012.dkr.ecr.us-east-1.amazonaws.com/pikmin-postcard:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "PORT",
          "value": "3000"
        },
        {
          "name": "GEMINI_MODEL",
          "value": "gemini-2.0-flash"
        }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:ssm:us-east-1:123456789012:parameter/pikmin-postcard/DATABASE_URL"
        },
        {
          "name": "GOOGLE_GENERATIVE_AI_API_KEY",
          "valueFrom": "arn:aws:ssm:us-east-1:123456789012:parameter/pikmin-postcard/GOOGLE_GENERATIVE_AI_API_KEY"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/pikmin-postcard",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
