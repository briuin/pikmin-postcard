{
  "family": "pikmin-postcard-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::041913718278:role/pikmin-postcard-task-execution",
  "taskRoleArn": "arn:aws:iam::041913718278:role/pikmin-postcard-task",
  "containerDefinitions": [
    {
      "name": "pikmin-postcard-app",
      "image": "041913718278.dkr.ecr.us-east-1.amazonaws.com/pikmin-postcard:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "PORT",
          "value": "3000"
        },
        {
          "name": "GEMINI_MODEL",
          "value": "gemini-2.5-flash"
        },
        {
          "name": "S3_BUCKET_NAME",
          "value": "pikmin-postcard-images-041913718278-20260226"
        },
        {
          "name": "S3_REGION",
          "value": "us-east-1"
        },
        {
          "name": "S3_PUBLIC_BASE_URL",
          "value": "https://pikmin-postcard-images-041913718278-20260226.s3.us-east-1.amazonaws.com"
        },
        {
          "name": "NEXTAUTH_URL",
          "value": "https://pikmin.askans.app"
        },
        {
          "name": "NEXT_PUBLIC_SERVERLESS_API_BASE_URL",
          "value": "https://q5wrip39qe.execute-api.us-east-1.amazonaws.com"
        }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:ssm:us-east-1:041913718278:parameter/pikmin-postcard/DATABASE_URL"
        },
        {
          "name": "GOOGLE_GENERATIVE_AI_API_KEY",
          "valueFrom": "arn:aws:ssm:us-east-1:041913718278:parameter/pikmin-postcard/GOOGLE_GENERATIVE_AI_API_KEY"
        },
        {
          "name": "GOOGLE_CLIENT_ID",
          "valueFrom": "arn:aws:ssm:us-east-1:041913718278:parameter/pikmin-postcard/GOOGLE_CLIENT_ID"
        },
        {
          "name": "GOOGLE_CLIENT_SECRET",
          "valueFrom": "arn:aws:ssm:us-east-1:041913718278:parameter/pikmin-postcard/GOOGLE_CLIENT_SECRET"
        },
        {
          "name": "NEXTAUTH_SECRET",
          "valueFrom": "arn:aws:ssm:us-east-1:041913718278:parameter/pikmin-postcard/NEXTAUTH_SECRET"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/pikmin-postcard",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
