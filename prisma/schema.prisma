generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LocationStatus {
  AUTO
  USER_CONFIRMED
  MANUAL
}

enum DetectionJobStatus {
  QUEUED
  PROCESSING
  SUCCEEDED
  FAILED
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  postcards     Postcard[]
  detectionJobs DetectionJob[]
}

model Postcard {
  id                   String         @id @default(cuid())
  userId               String
  title                String
  notes                String?
  imageUrl             String?
  capturedAt           DateTime?
  city                 String?
  country              String?
  placeName            String?
  latitude             Float?
  longitude            Float?
  aiLatitude           Float?
  aiLongitude          Float?
  aiConfidence         Float?
  aiPlaceGuess         String?
  likeCount            Int            @default(0)
  dislikeCount         Int            @default(0)
  wrongLocationReports Int            @default(0)
  locationStatus       LocationStatus @default(AUTO)
  locationModelVersion String?
  deletedAt            DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags                 PostcardTag[]

  @@index([userId, createdAt])
  @@index([deletedAt])
}

model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  createdAt DateTime     @default(now())
  postcards PostcardTag[]
}

model PostcardTag {
  postcardId String
  tagId      String
  postcard   Postcard @relation(fields: [postcardId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postcardId, tagId])
}

model DetectionJob {
  id           String             @id @default(cuid())
  userId       String
  imageUrl     String
  status       DetectionJobStatus @default(QUEUED)
  latitude     Float?
  longitude    Float?
  confidence   Float?
  placeGuess   String?
  errorMessage String?
  modelVersion String?
  completedAt  DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}
