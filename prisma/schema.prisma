generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LocationStatus {
  AUTO
  USER_CONFIRMED
  MANUAL
}

enum DetectionJobStatus {
  QUEUED
  PROCESSING
  SUCCEEDED
  FAILED
}

enum FeedbackAction {
  LIKE
  DISLIKE
  REPORT_WRONG_LOCATION
}

enum PostcardEditAction {
  DETAILS_UPDATED
  CROP_UPDATED
  SOFT_DELETED
}

enum UserRole {
  MEMBER
  MANAGER
  ADMIN
}

enum FeedbackMessageStatus {
  OPEN
  CLOSED
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  displayName   String?
  role          UserRole       @default(MEMBER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  postcards     Postcard[]
  detectionJobs DetectionJob[]
  feedbacks     PostcardFeedback[]
  feedbackMessages FeedbackMessage[]
  editHistory   PostcardEditHistory[]
}

model Postcard {
  id                   String         @id @default(cuid())
  userId               String
  title                String
  notes                String?
  imageUrl             String?
  originalImageUrl     String?
  capturedAt           DateTime?
  city                 String?
  country              String?
  placeName            String?
  latitude             Float?
  longitude            Float?
  aiLatitude           Float?
  aiLongitude          Float?
  aiConfidence         Float?
  aiPlaceGuess         String?
  likeCount            Int            @default(0)
  dislikeCount         Int            @default(0)
  wrongLocationReports Int            @default(0)
  locationStatus       LocationStatus @default(AUTO)
  locationModelVersion String?
  deletedAt            DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags                 PostcardTag[]
  feedbacks            PostcardFeedback[]
  editHistory          PostcardEditHistory[]

  @@index([userId, createdAt])
  @@index([deletedAt])
}

model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  createdAt DateTime     @default(now())
  postcards PostcardTag[]
}

model PostcardTag {
  postcardId String
  tagId      String
  postcard   Postcard @relation(fields: [postcardId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postcardId, tagId])
}

model DetectionJob {
  id           String             @id @default(cuid())
  userId       String
  imageUrl     String
  status       DetectionJobStatus @default(QUEUED)
  latitude     Float?
  longitude    Float?
  confidence   Float?
  placeGuess   String?
  errorMessage String?
  modelVersion String?
  completedAt  DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model PostcardFeedback {
  id        String         @id @default(cuid())
  postcardId String
  userId    String
  action    FeedbackAction
  createdAt DateTime       @default(now())
  postcard  Postcard       @relation(fields: [postcardId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postcardId, userId, action])
  @@index([userId, createdAt])
  @@index([postcardId, createdAt])
}

model PostcardEditHistory {
  id         String            @id @default(cuid())
  postcardId String
  userId     String
  action     PostcardEditAction
  beforeData Json?
  afterData  Json?
  createdAt  DateTime          @default(now())
  postcard   Postcard          @relation(fields: [postcardId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postcardId, createdAt])
  @@index([userId, createdAt])
}

model FeedbackMessage {
  id        String                @id @default(cuid())
  userId    String
  subject   String
  message   String
  status    FeedbackMessageStatus @default(OPEN)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}
