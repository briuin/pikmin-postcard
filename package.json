{
  "name": "pikmin-postcard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "opennext:deploy": "sst deploy --stage production",
    "opennext:deploy:preview": "sst deploy --stage preview",
    "opennext:outputs": "sst state export --stage production",
    "opennext:remove:preview": "sst remove --stage preview",
    "clean:next": "node scripts/clean-next.mjs",
    "prebuild": "npm run clean:next",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "tsx --test --test-concurrency=1 tests/**/*.test.ts",
    "test:integration": "npm run build && tsx --test --test-concurrency=1 tests/integration/**/*.test.ts",
    "ddb:provision": "node scripts/provision-dynamodb.mjs",
    "ddb:clear": "node scripts/clear-dynamodb-tables.mjs",
    "ddb:backfill:geo": "node scripts/backfill-postcard-geo-buckets.mjs",
    "seed:postcards": "node scripts/seed-random-postcards.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1002.0",
    "@aws-sdk/client-s3": "^3.862.0",
    "@aws-sdk/client-sqs": "^3.1003.0",
    "@aws-sdk/lib-dynamodb": "^3.1002.0",
    "@aws-sdk/s3-request-presigner": "^3.1002.0",
    "@prisma/client": "^6.4.1",
    "leaflet": "^1.9.4",
    "next": "^15.1.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-image-crop": "^11.0.10",
    "react-leaflet": "^5.0.0",
    "sharp": "^0.34.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/leaflet": "^1.9.15",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.7",
    "postcss": "^8.5.6",
    "prisma": "^6.4.1",
    "sst": "^4.1.10",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
